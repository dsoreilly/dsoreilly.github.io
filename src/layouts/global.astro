---
import "../styles/global.css";
import { Font } from "astro:assets";

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <Font cssVariable="--font-fraunces" />
  </head>
  <body
    class="bg-dawn-base dark:bg-moon-base text-dawn-text dark:text-moon-text font-serif antialiased"
  >
    <div class="mx-auto mt-16 w-full max-w-lg px-4 lg:max-w-2xl lg:px-8">
      <slot />
    </div>
  </body>
</html>

